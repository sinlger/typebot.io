# ================== RELEASE ======================
FROM node:24-bullseye-slim AS release

WORKDIR /app

# Nitro server output (self-contained, includes traced dependencies)
COPY apps/landing-page-v2/.output/server ./server

# Static assets served by Nitro
COPY apps/landing-page-v2/.output/public ./public

USER node
EXPOSE 3000
ENV PORT=3000 HOST=0.0.0.0
CMD ["node", "./server/index.mjs"]
